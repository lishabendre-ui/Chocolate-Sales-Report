	hierarchy 'Year Hierarchy'
		lineageTag: 36a68565-e097-476f-80f8-ef379931c020

		level Year
			lineageTag: f94c9c3d-b22c-43ac-914b-5ff9d3683b36
			column: Year

		level Quarter
			lineageTag: 38d0e2a0-7985-4077-bf0f-1f1e18ba5dac
			column: Quarter

		level Month
			lineageTag: 5ecf0614-660e-48f2-8dbe-f4adec010f26
			column: Month

		level Day
			lineageTag: c3b0929b-a642-476a-a9fe-2ab09daa885b
			column: Day

	partition Calendar = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(
				        DATE(YEAR(MIN(fact_sales[Date])), 1, 1),
				        DATE(YEAR(MAX(fact_sales[Date])), 12, 31)
				    ),
				    "Year",       YEAR([Date]),
				    "MonthNo",    MONTH([Date]),
				    "Month",      FORMAT([Date], "MMMM"),
				    "MonthShort", FORMAT([Date], "MMM"),
				    "Quarter",    "Q" & QUARTER([Date]),
				    "QuarterNo",  QUARTER([Date]),
				    "WeekNo",     WEEKNUM([Date]),
				    "Day",        DAY([Date]),
				    "DayName",    FORMAT([Date], "DDDD"),
				    "DayOfWeek",  WEEKDAY([Date], 2),
				    "IsWeekend",  IF(WEEKDAY([Date], 2) >= 6, TRUE(), FALSE()),
				    "YearMonth",  FORMAT([Date], "YYYY-MM"),
				    "FiscalYear", "FY" & IF(MONTH([Date]) >= 7, YEAR([Date]) + 1, YEAR([Date])))

	annotation PBI_Id = 5aade61661d247e2990260a49ac63046

