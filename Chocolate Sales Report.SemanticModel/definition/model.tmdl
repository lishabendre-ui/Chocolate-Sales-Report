model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-NL
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

annotation PBI_QueryOrder = ["dim_customers","dim_geo","dim_salesperson","dim_products","fact_sales","fact_targets"]

ref table dim_customers
ref table dim_geo
ref table dim_salesperson
ref table dim_products
ref table fact_sales
ref table fact_targets

ref cultureInfo en-US

